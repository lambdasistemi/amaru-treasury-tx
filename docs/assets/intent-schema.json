{
    "$defs": {
        "assetMap": {
            "additionalProperties": {
                "additionalProperties": {
                    "minimum": 0,
                    "type": "integer"
                },
                "propertyNames": {
                    "$ref": "#/$defs/assetNameHex"
                },
                "type": "object"
            },
            "propertyNames": {
                "$ref": "#/$defs/hex28"
            },
            "type": "object"
        },
        "assetNameHex": {
            "pattern": "^([0-9a-fA-F]{2})*$",
            "type": "string"
        },
        "bech32Address": {
            "pattern": "^addr(_test)?1[0-9a-z]+$",
            "type": "string"
        },
        "disburse": {
            "additionalProperties": false,
            "properties": {
                "amount": {
                    "minimum": 1,
                    "type": "integer"
                },
                "beneficiaryAddress": {
                    "$ref": "#/$defs/bech32Address"
                },
                "unit": {
                    "enum": [
                        "ada",
                        "usdm"
                    ],
                    "type": "string"
                },
                "usdmPolicy": {
                    "$ref": "#/$defs/hex28"
                },
                "usdmToken": {
                    "$ref": "#/$defs/assetNameHex"
                }
            },
            "required": [
                "unit",
                "amount",
                "beneficiaryAddress",
                "usdmPolicy",
                "usdmToken"
            ],
            "type": "object"
        },
        "governance-withdrawal-init-materialization": {
            "additionalProperties": false,
            "properties": {
                "registryRefTxIn": {
                    "$ref": "#/$defs/txIn"
                },
                "rewardsLovelace": {
                    "minimum": 1,
                    "type": "integer"
                },
                "treasuryAddress": {
                    "$ref": "#/$defs/bech32Address"
                },
                "treasuryRefTxIn": {
                    "$ref": "#/$defs/txIn"
                },
                "treasuryRewardAccountHash": {
                    "$ref": "#/$defs/hex28"
                }
            },
            "required": [
                "treasuryRewardAccountHash",
                "treasuryAddress",
                "treasuryRefTxIn",
                "registryRefTxIn",
                "rewardsLovelace"
            ],
            "type": "object"
        },
        "governance-withdrawal-init-proposal": {
            "additionalProperties": false,
            "properties": {
                "anchorHash": {
                    "$ref": "#/$defs/hex32"
                },
                "anchorUrl": {
                    "maxLength": 128,
                    "minLength": 1,
                    "type": "string"
                },
                "fundingStakeKeyHash": {
                    "$ref": "#/$defs/hex28"
                },
                "treasuryRewardAccountHash": {
                    "$ref": "#/$defs/hex28"
                },
                "voterKeyHash": {
                    "$ref": "#/$defs/hex28"
                },
                "withdrawalAmountLovelace": {
                    "minimum": 1,
                    "type": "integer"
                }
            },
            "required": [
                "treasuryRewardAccountHash",
                "withdrawalAmountLovelace",
                "fundingStakeKeyHash",
                "voterKeyHash",
                "anchorUrl",
                "anchorHash"
            ],
            "type": "object"
        },
        "hex28": {
            "pattern": "^([0-9a-fA-F]{56})$",
            "type": "string"
        },
        "hex32": {
            "pattern": "^([0-9a-fA-F]{64})$",
            "type": "string"
        },
        "rationale": {
            "additionalProperties": false,
            "properties": {
                "description": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "items": {
                                "type": "string"
                            },
                            "minItems": 1,
                            "type": "array"
                        }
                    ]
                },
                "destinationLabel": {
                    "type": "string"
                },
                "event": {
                    "type": "string"
                },
                "justification": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "items": {
                                "type": "string"
                            },
                            "minItems": 1,
                            "type": "array"
                        }
                    ]
                },
                "label": {
                    "type": "string"
                },
                "references": {
                    "default": [],
                    "items": {
                        "additionalProperties": false,
                        "properties": {
                            "@type": {
                                "default": "Other",
                                "description": "SundaeSwap reference type. Default 'Other'.",
                                "maxLength": 64,
                                "minLength": 1,
                                "type": "string"
                            },
                            "label": {
                                "description": "Human-readable label. Literal ' - ' marks the split for the on-chain Metadatum 3-chunk shape.",
                                "maxLength": 256,
                                "minLength": 1,
                                "type": "string"
                            },
                            "uri": {
                                "description": "Full URI of the reference document (e.g. ipfs://<CID>, https://..., ar://...). Chunked per the metadatum 64-byte cap at serialisation time.",
                                "maxLength": 256,
                                "minLength": 1,
                                "type": "string"
                            }
                        },
                        "required": [
                            "uri",
                            "label"
                        ],
                        "type": "object"
                    },
                    "type": "array"
                }
            },
            "required": [
                "event",
                "label",
                "description",
                "justification",
                "destinationLabel"
            ],
            "type": "object"
        },
        "registry-init-mint": {
            "additionalProperties": false,
            "properties": {
                "ownerKeyHash": {
                    "$ref": "#/$defs/hex28"
                },
