            "required": [
                "id",
                "treasuryAddress",
                "treasuryUtxos",
                "treasuryLeftoverLovelace",
                "treasuryLeftoverUsdm",
                "treasuryLeftoverOtherAssets",
                "treasuryScriptHash",
                "permissionsRewardAccount",
                "scopesDeployedAt",
