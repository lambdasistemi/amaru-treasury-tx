cabal-version:      3.4
name:               amaru-treasury-tx
version:            0.2.14.0
synopsis:           Build unsigned Amaru treasury transactions
description:
  Haskell port of the Amaru treasury bash recipes
  ('disburse', 'reorganize', 'withdraw') from
  pragma-org/amaru-treasury/journal/2026/. The CLI
  emits unsigned Conway transactions for offline
  signing.

license:            Apache-2.0
license-file:       LICENSE
author:             Paolo Veronelli
maintainer:         paolo.veronelli@gmail.com
category:           Cardano
build-type:         Simple
extra-doc-files:    CHANGELOG.md
extra-source-files:
  assets/plutus/permissions.cbor
  assets/plutus/README.md
  assets/plutus/scopes.cbor
  assets/plutus/sundae_order.cbor
  assets/plutus/treasury.cbor
  assets/plutus/treasury_registry.cbor
  docs/assets/asciinema/*.cast
  docs/assets/intent-schema.json
  docs/assets/treasury-inspect-schema.json
  docs/assets/tx-report-schema.json
  scripts/smoke/cardano-cli-envelope-oracle
  scripts/smoke/devnet-local
  scripts/smoke/smoke.sh
  scripts/smoke/swap-quote-docs
  scripts/smoke/swap-quote-override
  scripts/smoke/swap-wizard-signers
  scripts/smoke/treasury-inspect
  scripts/smoke/tx-build-pipe
  test/fixtures/106-cardano-cli-oracle/*.addr
  test/fixtures/106-cardano-cli-oracle/*.cborHex
  test/fixtures/106-cardano-cli-oracle/*.json
  test/fixtures/106-cardano-cli-oracle/*.md
  test/fixtures/106-cardano-cli-oracle/*.version
  test/fixtures/118-vault-witness/*.addr
  test/fixtures/118-vault-witness/*.addr_xsk
  test/fixtures/118-vault-witness/*.hash
  test/fixtures/118-vault-witness/*.hex
  test/fixtures/118-vault-witness/*.json
  test/fixtures/118-vault-witness/*.md
  test/fixtures/118-vault-witness/*.skey
  test/fixtures/118-vault-witness/*.vkey
  test/fixtures/disburse/**/*.cbor
  test/fixtures/disburse/**/*.json
  test/fixtures/disburse/**/*.md
  test/fixtures/disburse-wizard/**/*.json
  test/fixtures/registry-init-wizard/*.json
  test/fixtures/swap/**/*.cbor
  test/fixtures/swap/**/*.json
  test/fixtures/swap/**/*.md
  test/fixtures/swap-quote/**/*.json
  test/fixtures/swap-quote/**/*.md
  test/fixtures/swap-wizard/**/*.json
  test/fixtures/withdraw/**/*.cbor
  test/fixtures/withdraw/**/*.json

flag werror
  description: Enable -Werror
  manual:      True
  default:     False

common warnings
  ghc-options:
    -Wall -Wunused-imports -Wmissing-export-lists -Wname-shadowing
    -Wredundant-constraints

  if flag(werror)
    ghc-options: -Werror

  default-extensions:
    DataKinds
    DerivingStrategies
    DuplicateRecordFields
    FlexibleContexts
    GADTs
    ImportQualifiedPost
    LambdaCase
    OverloadedStrings
    PatternSynonyms
    ScopedTypeVariables
    StrictData
    TypeApplications
    TypeOperators
    ViewPatterns

