                },
                "upperBound": {
                    "minimum": 0,
                    "type": "integer"
                },
                "walletUtxo": {
                    "$ref": "#/$defs/txIn"
                }
            },
            "required": [
                "walletUtxo",
                "treasuryUtxos",
                "treasuryAddress",
                "treasuryDeployedAt",
                "registryDeployedAt",
                "permissionsRewardAccount",
                "permissionsDeployedAt",
                "scopeOwnerSigner",
                "upperBound"
            ],
            "type": "object"
        },
        "rewardAccount": {
            "pattern": "^stake(_test)?1[0-9a-z]+$",
            "type": "string"
        },
        "scope": {
            "additionalProperties": false,
            "properties": {
                "id": {
                    "enum": [
                        "core_development",
                        "ops_and_use_cases",
                        "network_compliance",
                        "middleware",
