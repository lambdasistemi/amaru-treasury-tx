#!/usr/bin/env bash
set -euo pipefail

cabal build exe:amaru-treasury-tx -O0 >/dev/null
exe="$(cabal list-bin exe:amaru-treasury-tx -O0)"

tmp="$(mktemp -d)"
cleanup() {
  rm -rf "$tmp"
}
trap cleanup EXIT

tx="$tmp/rerate.cbor.hex"
report="$tmp/rerate.report.json"
order="aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa#0"

"$exe" swap-rerate \
  --metadata test/fixtures/metadata.json \
  --scope network_compliance \
  --fixture-wallet-txin 42e4c279036e3ab6070bc969392b823917d8b998204d5dcbdfe69fec4b442da0#0 \
  --order-txin "$order" \
  --new-rate 0.3 \
  --out "$tx" \
  --report "$report"

if [[ ! -s "$tx" ]]; then
  printf 'swap-rerate-offline: empty unsigned artifact\n' >&2
  exit 1
fi

if ! grep -Eq '^[0-9a-f]+$' "$tx"; then
  printf 'swap-rerate-offline: unsigned artifact is not hex\n' >&2
  exit 1
fi

jq -e \
  --arg order "$order" \
  '.status == "single_tx"
    and (.selectedOrders | any(.txIn == $order))
    and .newRate == 0.3' \
  "$report" >/dev/null

printf 'swap-rerate-offline: OK\n'
