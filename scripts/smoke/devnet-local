#!/usr/bin/env bash
set -euo pipefail

phase="node"
run_dir=""
reward_timeout_seconds="600"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --phase)
      phase="${2:?missing value for --phase}"
      shift 2
      ;;
    --run-dir)
      run_dir="${2:?missing value for --run-dir}"
      shift 2
      ;;
    --reward-timeout-seconds)
      reward_timeout_seconds="${2:?missing value for --reward-timeout-seconds}"
      shift 2
      ;;
    node|governance|withdraw|swap-ready|scoop-m2|scoop-e2e|treasury-swap-e2e|treasury-swap-full-e2e|mixed-utxo|registry-init|stake-reward-init|governance-withdrawal-init|disburse-submit|all)
      phase="$1"
      shift
      ;;
    *)
      echo "devnet-smoke: unknown argument: $1" >&2
      exit 64
      ;;
  esac
done

if [[ "$phase" != "node" && "$phase" != "governance" && "$phase" != "withdraw" && "$phase" != "swap-ready" && "$phase" != "scoop-m2" && "$phase" != "scoop-e2e" && "$phase" != "treasury-swap-e2e" && "$phase" != "treasury-swap-full-e2e" && "$phase" != "mixed-utxo" && "$phase" != "registry-init" && "$phase" != "stake-reward-init" && "$phase" != "governance-withdrawal-init" && "$phase" != "disburse-submit" && "$phase" != "all" ]]; then
  echo "devnet-smoke: unknown phase: $phase" >&2
  exit 64
fi

if [[ -z "$run_dir" ]]; then
  run_dir="runs/devnet/$(date -u +%Y%m%dT%H%M%SZ)"
fi

export DEVNET_SMOKE_PHASE="$phase"
export DEVNET_SMOKE_RUN_DIR="$run_dir"
export DEVNET_SMOKE_REWARD_TIMEOUT_SECONDS="$reward_timeout_seconds"

if [[ "$phase" == "all" ]]; then
  "$0" --phase node --run-dir "$run_dir/node"
  "$0" --phase governance --run-dir "$run_dir/governance"
  "$0" --phase governance-withdrawal-init --run-dir "$run_dir/governance-withdrawal-init"
  "$0" --phase disburse-submit --run-dir "$run_dir/disburse-submit"
  "$0" --phase mixed-utxo --run-dir "$run_dir/mixed-utxo"
else
  cabal test devnet-tests -O0 \
    --test-show-details=direct \
    --test-option=--match \
    --test-option="$phase"
fi
