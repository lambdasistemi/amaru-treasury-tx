                "registrySeedTxIn": {
                    "$ref": "#/$defs/txIn"
                },
                "scopesSeedTxIn": {
                    "$ref": "#/$defs/txIn"
                }
            },
            "required": [
                "scopesSeedTxIn",
                "registrySeedTxIn"
            ],
            "type": "object"
        },
        "registry-init-seed-split": {
            "additionalProperties": false,
            "properties": {},
            "required": [],
            "type": "object"
        },
        "reorganize": {
            "additionalProperties": false,
            "properties": {
                "permissionsDeployedAt": {
                    "$ref": "#/$defs/txIn"
                },
                "permissionsRewardAccount": {
                    "$ref": "#/$defs/rewardAccount"
                },
                "registryDeployedAt": {
                    "$ref": "#/$defs/txIn"
