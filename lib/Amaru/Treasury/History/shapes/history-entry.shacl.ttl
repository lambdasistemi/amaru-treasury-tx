@prefix atx: <https://lambdasistemi.github.io/amaru-treasury-tx/vocab/history#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

atx:HistoryEntryShape a sh:NodeShape ;
  sh:targetClass atx:HistoryEntry ;
  sh:property [
    sh:path atx:tx ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI
  ] ;
  sh:property [
    sh:path atx:txid ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path atx:slot ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:integer
  ] ;
  sh:property [
    sh:path atx:scope ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path atx:role ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string
  ] ;
  sh:property [
    sh:path atx:direction ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:datatype xsd:string
  ] .
