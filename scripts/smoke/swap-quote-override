#!/usr/bin/env bash
set -euo pipefail

cabal build exe:amaru-treasury-tx -O0 >/dev/null
exe="$(cabal list-bin exe:amaru-treasury-tx -O0)"
root_help="$("$exe" --help)"
quote_help="$("$exe" swap-quote --help)"
wizard_help="$("$exe" swap-wizard --help)"

grep -F -- "swap-quote" <<<"$root_help" >/dev/null || {
  printf 'top-level help missing swap-quote command\n' >&2
  exit 1
}

for needle in \
  "--ada-usdm DECIMAL" \
  "--price-source SOURCE" \
  "--slippage-bps INT" \
  "--out-dir PATH"
do
  grep -F -- "$needle" <<<"$quote_help" >/dev/null || {
    printf 'swap-quote help missing: %s\n' "$needle" >&2
    exit 1
  }
done

for retired in "--ada-usd DECIMAL"
do
  if grep -F -- "$retired" <<<"$quote_help" >/dev/null; then
    printf 'swap-quote still advertises retired flag: %s\n' "$retired" >&2
    exit 1
  fi
done

for needle in \
  "--min-rate USDM_PER_ADA" \
  "--ada-usdm USDM_PER_ADA" \
  "--slippage-bps INT" \
  "--out PATH"
do
  grep -F -- "$needle" <<<"$wizard_help" >/dev/null || {
    printf 'swap-wizard help missing: %s\n' "$needle" >&2
    exit 1
  }
done

for retired in "--ada-usd DECIMAL" "--price-source SOURCE"
do
  if grep -F -- "$retired" <<<"$wizard_help" >/dev/null; then
    printf 'swap-wizard still advertises retired flag: %s\n' "$retired" >&2
    exit 1
  fi
done

cabal test unit-tests -O0 \
  --test-show-details=direct \
  --test-option=--match \
  --test-option="swap-quote runner planning"

printf 'swap-quote-override: OK\n'
